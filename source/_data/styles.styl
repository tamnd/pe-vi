// Make MathJax math blend with Be Vietnam Pro by matching font size and weight
mjx-container[jax="CHTML"] {
  font-size: 0.95em !important;
  line-height: 1.6 !important;
}

// Prevent MathJax from rendering in a visually jarring weight in headings
h1 mjx-container, h2 mjx-container, h3 mjx-container {
  font-size: 0.9em !important;
}

// Hide the footer completely
.footer, #footer {
  display: none !important;
}
