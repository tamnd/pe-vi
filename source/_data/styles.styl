// Make MathJax math blend with Be Vietnam Pro by matching font size and weight
mjx-container[jax="CHTML"] {
  font-size: 0.95em !important;
  line-height: 1.6 !important;
}

// Prevent MathJax from rendering in a visually jarring weight in headings
h1 mjx-container, h2 mjx-container, h3 mjx-container {
  font-size: 0.9em !important;
}

// Hide the footer completely
.footer, #footer {
  display: none !important;
}

// Markdown action bar injected after the problem title h1
.post-md-actions {
  margin-top: 0.4em;
  margin-bottom: 1.5em;
  display: flex;
  gap: 0.6em;
}

.post-md-btn {
  display: inline-block;
  padding: 0.25em 0.75em;
  font-size: 0.8em;
  font-family: inherit;
  color: #555;
  background: #f5f5f5;
  border: 1px solid #ddd;
  border-radius: 3px;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.15s;
}

.post-md-btn:hover {
  background: #e8e8e8;
  color: #333;
  text-decoration: none;
}
