// Make MathJax math blend with Be Vietnam Pro by matching font size and weight
mjx-container[jax="CHTML"] {
  font-size: 0.95em !important;
  line-height: 1.6 !important;
}

// Prevent MathJax from rendering in a visually jarring weight in headings
h1 mjx-container, h2 mjx-container, h3 mjx-container {
  font-size: 0.9em !important;
}

// Hide the footer completely
.footer, #footer {
  display: none !important;
}

// Markdown action bar placed right below the problem title h1
.post-md-actions {
  margin: 0.3em 0 0.3em 0;
  font-size: 1em;
  display: flex;
  gap: 1.2em;
}

.post-md-btn {
  font-family: inherit;
  font-size: inherit;
  color: #777;
  background: none;
  border: none;
  padding: 0;
  text-decoration: none;
  cursor: pointer;
}

.post-md-btn:hover {
  color: #333;
  background: none;
  text-decoration: none;
}
