// Make MathJax math blend with Be Vietnam Pro by matching font size and weight
mjx-container[jax="CHTML"] {
  font-size: 0.95em !important;
  line-height: 1.6 !important;
}

// Prevent MathJax from rendering in a visually jarring weight in headings
h1 mjx-container, h2 mjx-container, h3 mjx-container {
  font-size: 0.9em !important;
}

// Hide the footer completely
.footer, #footer {
  display: none !important;
}

// Markdown action bar at the top-right of the post
.post-md-actions {
  float: right;
  display: flex;
  gap: 0.5em;
  margin-top: 0.5em;
}

.post-md-btn {
  display: inline-block;
  font-size: 0.8em;
  font-family: inherit;
  color: #aaa;
  background: none;
  border: none;
  padding: 0;
  text-decoration: none;
  cursor: pointer;
}

.post-md-btn:hover {
  color: #555;
  text-decoration: underline;
}
